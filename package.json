{
  "name": "notion-snap",
  "version": "0.1.0",
  "description": "🫧 Open-source Notion workspace backup & restore tool. OAuth-based, Git-friendly, with version history.",
  "main": "dist/index.js",
  "bin": {
    "notion-snap": "dist/index.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "ts-node src/index.ts",
    "start": "node dist/index.js",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "keywords": [
    "notion",
    "backup",
    "restore",
    "git",
    "open-source",
    "oauth",
    "markdown"
  ],
  "author": {
    "name": "力工王"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/Vomoon9/notion-snap.git"
  },
  "homepage": "https://github.com/Vomoon9/notion-snap",
  "bugs": {
    "url": "https://github.com/Vomoon9/notion-snap/issues"
  },
  "files": [
    "dist/**/*",
    "README.md",
    "LICENSE",
    ".env.example"
  ],
  "dependencies": {
    "@notionhq/client": "^2.0.0",
    "commander": "^12.0.0",
    "dotenv": "^16.4.0",
    "open": "^10.0.0",
    "simple-git": "^3.25.0",
    "yaml": "^2.4.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "ts-node": "^10.9.0",
    "typescript": "^5.5.0",
    "vitest": "^2.0.0"
  }
}